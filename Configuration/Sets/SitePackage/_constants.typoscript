######################
#### CONSTANTS ####
######################

# OpenStreetMap Configuration
plugin.tx_odsosm_pi1 {
    # Map dimensions
    width = 100%
    height = 500px

    # Default map center (emden)
    default_lon = 7.2060
    default_lat = 53.3594
    default_zoom = 16

    # Library choice: leaflet
    library = leaflet
}
